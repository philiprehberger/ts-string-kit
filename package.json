{
  "name": "@philiprehberger/string-kit",
  "version": "0.1.5",
  "description": "String manipulation utilities — truncate, pad, wrap, template",
  "keywords": [
    "string",
    "truncate",
    "template",
    "pluralize",
    "pad",
    "wrap",
    "escape"
  ],
  "author": "Philip Rehberger",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-string-kit.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-string-kit#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-string-kit/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2",
    "unrun": "^0.3.1"
  }
}
